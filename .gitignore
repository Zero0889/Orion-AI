__pycache__/
*.pyc
*.pyo
.verify*.py
.test*.py
.venv/
logs/

# ── Backups locales (versiones viejas; git ya guarda el historial) ──────────
ui_backup.py
*.bak
*.bak.json

# ── Configuración local del usuario ────────────────────────────────────────
config/theme.json

# ── SECRETOS — NUNCA subir a git ────────────────────────────────────────────
# Las claves y tokens de OAuth se guardan localmente; cada usuario rota las
# suyas. Si necesitas un ejemplo, crea `config/api_keys.example.json` con
# campos vacíos.
config/api_keys.json
config/credentials.json
config/gdrive_token.json
config/providers.json
config/telegram.json
config/access.json
config/gog.env
tools/gmail/

# ── Drop-zone web (Fase 4): archivos subidos por el usuario ─────────────────
uploads/

# ── Build artifacts ────────────────────────────────────────────────────────
web/node_modules/
web/dist/

# ── Herramientas del entorno (no son parte del producto) ────────────────────
.agents/
.claude/
skills-lock.json

# CLI binarios auxiliares descargados por core.cli_installer
tools/

# ── Notas y auditorías locales (no son parte del producto) ──────────────────
AUDIT*.md
NOTES*.md

# ── Trabajo académico en curso (paper STEM IEEE) ────────────────────────────
# Los drafts del paper viven en /paper localmente. Tienen marcadores [TODO]
# y [DATOS] mientras se redacta y se recolectan métricas del despliegue del
# ESP32. Untrack del repo hasta que esté listo para publicar.
paper/

# ── Estado runtime (flags, locks, pids) ─────────────────────────────────────
config/*.flag
*.pid
*.lock

# ── State runtime SQLite (Fase 3B) ──────────────────────────────────────────
# El DB real vive en data/ — gitignored. Solo el .gitkeep va a git para
# que la carpeta exista al clonar. Los -wal y -shm son auxiliares de WAL.
data/*.sqlite
data/*.sqlite-wal
data/*.sqlite-shm
data/*.sqlite.bak

# ── JSON legacy que la migración archiva ────────────────────────────────────
config/*.migrated_to_sqlite_*.bak

# ── Caches de tooling ───────────────────────────────────────────────────────
.ruff_cache/
.mypy_cache/
.pytest_cache/
.coverage
htmlcov/
node_modules/

# ── Atajos y artefactos del SO ──────────────────────────────────────────────
*.lnk
.DS_Store
Thumbs.db
desktop.ini
