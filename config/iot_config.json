  "transports": {
    "esp32_mqtt": {
      "type": "mqtt",
      "host": "broker.hivemq.com",
      "client_id": "orion",
      "port": 1883
    }
  },
  "devices": {
    "sensor_temperatura": {
      "name": "sensor de temperatura",
