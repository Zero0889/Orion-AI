        "sensor": "humidity"
      },
      "mqtt": {
        "topic_state": "orion/zahir/esp_sensores/dht",
        "sensor_field": "humedad"
      }
    },
    "sensor_luz": {
      "name": "sensor de luz",
      "transport": "esp32_mqtt",
      "capabilities": {
        "on_off": false,
        "dimmable": false,
        "rgb": false,
        "sensor": "light"
      },
      "mqtt": {
        "topic_state": "orion/zahir/esp_sensores/lux"
