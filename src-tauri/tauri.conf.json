{
  "$schema": "https://schema.tauri.app/config/1",
  "build": {
    "beforeDevCommand":   "npm --prefix web run dev",
    "beforeBuildCommand": "npm --prefix web run build",
    "devPath":   "http://localhost:5173",
    "distDir":   "../web/dist",
    "withGlobalTauri": false
  },
  "package": {
    "productName": "Orion",
    "version":     "0.1.2"
  },
  "tauri": {
    "allowlist": {
      "all":     false,
      "shell":   { "all": false, "open": true, "sidecar": true,
                    "scope": [
                      { "name": "binaries/orion-backend", "sidecar": true, "args": true }
                    ] },
      "process": { "all": false, "exit": true }
    },
    "bundle": {
      "active":     true,
      "identifier": "ai.orion.app",
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ],
      "targets": "all",
      "externalBin": ["binaries/orion-backend"],
      "resources": [],
      "category": "Productivity",
      "shortDescription": "Asistente personal multimodal",
      "longDescription":  "Orion es un asistente de IA con voz, vision, automatizaciones y control IoT."
    },
    "windows": [
      {
        "title":   "Orion",
        "width":   1280,
        "height":  820,
        "minWidth":  900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "url":     "http://127.0.0.1:8765",
        "transparent": false,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  }
}
